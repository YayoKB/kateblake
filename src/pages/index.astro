---
import { Image } from "astro:assets";
import Head from "../components/Head.astro";
import "../styles/global.css";
import CircleScribble from "../icons/circle-scribble.svg";
import Star from "../icons/star1.svg";
import DownArrow from "../icons/down-arrow.svg";
import aurecon from "../images/aurecon.png";
import ngi from "../images/ngi.png";
import nml from "../images/nml.png";
import storage from "../images/storage.png";
import Diamond from "../icons/diamond.svg";
import Heart2 from "../icons/heart2.svg";
import Smile2 from "../icons/smile2.svg";
import lilly1 from "../images/lillyA.jpg";
import lilly2 from "../images/lillyB.jpg";
import LillyArrow from "../icons/arrow4.svg";
import LinkedIn from "../icons/linkedin.svg";
import Github from "../icons/github.svg";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <script is:inline>
      // Apply theme immediately to prevent flash
      const mode = localStorage.getItem("mode");
      if (mode === "light" || mode === "dark") {
        document.documentElement.style.setProperty("color-scheme", mode);
      }
    </script>

    <Head />
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/crit-h1-subset.woff2" />
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/crit-name-subset.woff2" />
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/crit-pen-subset.woff2" />
    <link rel="preload" as="font" type="font/woff2" crossorigin href="/fonts/crit-nav-subset.woff2" />
    <style>
      @font-face {
        font-family: "H1 Fallback";
        src: local("Arial"), local("Helvetica"), local("sans-serif");
      }

      /* critiical h1 */
      @font-face {
        font-family: "Lexend Zetta H1 Crit";
        src: url("/fonts/crit-h1-subset.woff2") format("woff2");
        font-weight: bold;
        font-style: normal;
        font-display: swap;
      }

      /* critical name */
      @font-face {
        font-family: "Lexend Zetta Name Crit";
        src: url("/fonts/crit-name-subset.woff2") format("woff2");
        font-weight: bold;
        font-style: normal;
        font-display: swap;
      }

      /* critical nav */
      @font-face {
        font-family: "Lexend Zetta Nav Crit";
        src: url("/fonts/crit-nav-subset.woff2") format("woff2");
        font-weight: 500;
        font-style: normal;
        font-display: swap;
      }

      /* critical handwriting */
      @font-face {
        font-family: "Nanum Pen Crit";
        src: url("/fonts/crit-pen-subset.woff2") format("woff2");
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }

      /* regular body font */
      @font-face {
        font-family: "Lexend Exa";
        src: url("/fonts/LexendExa-VariableFont_wght-subset.woff2") format("woff2");
        font-weight: 100 900;
        font-display: swap;
      }

      /* headings font */
      @font-face {
        font-family: "Lexend Zetta";
        src: url("/fonts/LexendZetta-VariableFont_wght-subset.woff2") format("woff2");
        font-weight: 100 900;
        font-display: swap;
      }

      /* handwriting font */
      @font-face {
        font-family: "Nanum Pen";
        src: url("/fonts/NanumPenScript-Regular-subset.woff2") format("woff2");
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }

      h1 {
        font-family: "Lexend Zetta H1 Crit", "H1 Fallback", sans-serif;
      }

      .intro .title .name {
        font-family: "Lexend Zetta Name Crit", "H1 Fallback", sans-serif;
      }

      header ul > li {
        font-family: "Lexend Zetta Nav Crit", "H1 Fallback", sans-serif;
      }

      .intro .handwriting {
        font-family: "Nanum Pen Crit", cursive;
      }

      body {
        font-family:
          "Lexend Exa",
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          Roboto,
          Helvetica,
          Arial,
          sans-serif,
          "Apple Color Emoji",
          "Segoe UI Emoji",
          "Segoe UI Symbol";
      }
    </style>
  </head>
  <body>
    <header>
      <svg class="visually-hidden" aria-hidden="true">
        <defs>
          <filter id="wiggle">
            <feTurbulence baseFrequency="0.01" numOctaves="1" type="fractalNoise" result="turbulence">
              <animate attributeName="seed" dur="10s" repeatCount="indefinite" values="1; 30; 1"></animate>
            </feTurbulence>
            <feDisplacementMap in="SourceGraphic" in2="turbulence" scale="5" xChannelSelector="R" yChannelSelector="G"
            ></feDisplacementMap>
          </filter>
        </defs>
      </svg>
      <p class="logo">KB<span>.</span><span>!</span></p>
      <ul>
        <li>
          <a href="#about">
            About
            <CircleScribble />
          </a>
        </li>
        <li>
          <a href="#work">
            Work
            <CircleScribble />
          </a>
        </li>
        <li>
          <a href="#contact">
            Contact
            <CircleScribble />
          </a>
        </li>
      </ul>
      <div class="themes">
        <button id="themeToggle" aria-pressed="false" type="button"
          ><svg
            id="sunIcon"
            xmlns="http://www.w3.org/2000/svg"
            width="200"
            height="200"
            viewBox="0 0 24 24"
            fill="var(--foreground)"
            aria-hidden="true"
            ><g fill="none" stroke="var(--foreground)" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              ><path
                stroke-dasharray="36"
                stroke-dashoffset="36"
                d="M12 7c2.76 0 5 2.24 5 5c0 2.76 -2.24 5 -5 5c-2.76 0 -5 -2.24 -5 -5c0 -2.76 2.24 -5 5 -5"
                ><animate fill="freeze" attributeName="stroke-dashoffset" dur="0.5s" values="36;0"></animate></path
              ><path stroke-dasharray="2" stroke-dashoffset="2" d="M12 19v1M19 12h1M12 5v-1M5 12h-1" opacity="0"
                ><animate
                  fill="freeze"
                  attributeName="d"
                  begin="0.6s"
                  dur="0.2s"
                  values="M12 19v1M19 12h1M12 5v-1M5 12h-1;M12 21v1M21 12h1M12 3v-1M3 12h-1"></animate><animate
                  fill="freeze"
                  attributeName="stroke-dashoffset"
                  begin="0.6s"
                  dur="0.2s"
                  values="2;0"></animate><set fill="freeze" attributeName="opacity" begin="0.6s" to="1"
                ></set><animateTransform
                  attributeName="transform"
                  dur="30s"
                  repeatCount="indefinite"
                  type="rotate"
                  values="0 12 12;360 12 12"></animateTransform></path
              ><path
                stroke-dasharray="2"
                stroke-dashoffset="2"
                d="M17 17l0.5 0.5M17 7l0.5 -0.5M7 7l-0.5 -0.5M7 17l-0.5 0.5"
                opacity="0"
                ><animate
                  fill="freeze"
                  attributeName="d"
                  begin="0.8s"
                  dur="0.2s"
                  values="M17 17l0.5 0.5M17 7l0.5 -0.5M7 7l-0.5 -0.5M7 17l-0.5 0.5;M18.5 18.5l0.5 0.5M18.5 5.5l0.5 -0.5M5.5 5.5l-0.5 -0.5M5.5 18.5l-0.5 0.5"
                ></animate><animate fill="freeze" attributeName="stroke-dashoffset" begin="0.8s" dur="0.2s" values="2;0"
                ></animate><set fill="freeze" attributeName="opacity" begin="0.8s" to="1"></set><animateTransform
                  attributeName="transform"
                  dur="30s"
                  repeatCount="indefinite"
                  type="rotate"
                  values="0 12 12;360 12 12"></animateTransform></path
              ></g
            ></svg
          >
          <svg
            id="moonIcon"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            width="48"
            height="48"
            viewBox="0 0 24 24"
            ><g
              fill="none"
              stroke="var(--foreground)"
              stroke-dasharray="4"
              stroke-dashoffset="4"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M13 4h1.5M13 4h-1.5M13 4v1.5M13 4v-1.5"
                ><animate
                  id="lineMdMoonAltLoop0"
                  fill="freeze"
                  attributeName="stroke-dashoffset"
                  begin="0.7s;lineMdMoonAltLoop0.begin+6s"
                  dur="0.4s"
                  values="4;0"></animate><animate
                  fill="freeze"
                  attributeName="stroke-dashoffset"
                  begin="lineMdMoonAltLoop0.begin+2s;lineMdMoonAltLoop0.begin+4s"
                  dur="0.4s"
                  values="4;0"></animate><animate
                  fill="freeze"
                  attributeName="stroke-dashoffset"
                  begin="lineMdMoonAltLoop0.begin+1.2s;lineMdMoonAltLoop0.begin+3.2s;lineMdMoonAltLoop0.begin+5.2s"
                  dur="0.4s"
                  values="0;4"></animate><set
                  attributeName="d"
                  begin="lineMdMoonAltLoop0.begin+1.8s"
                  to="M12 5h1.5M12 5h-1.5M12 5v1.5M12 5v-1.5"></set><set
                  attributeName="d"
                  begin="lineMdMoonAltLoop0.begin+3.8s"
                  to="M12 4h1.5M12 4h-1.5M12 4v1.5M12 4v-1.5"></set><set
                  attributeName="d"
                  begin="lineMdMoonAltLoop0.begin+5.8s"
                  to="M13 4h1.5M13 4h-1.5M13 4v1.5M13 4v-1.5"></set></path
              ><path d="M19 11h1.5M19 11h-1.5M19 11v1.5M19 11v-1.5"
                ><animate
                  id="lineMdMoonAltLoop1"
                  fill="freeze"
                  attributeName="stroke-dashoffset"
                  begin="1.1s;lineMdMoonAltLoop1.begin+6s"
                  dur="0.4s"
                  values="4;0"></animate><animate
                  fill="freeze"
                  attributeName="stroke-dashoffset"
                  begin="lineMdMoonAltLoop1.begin+2s;lineMdMoonAltLoop1.begin+4s"
                  dur="0.4s"
                  values="4;0"></animate><animate
                  fill="freeze"
                  attributeName="stroke-dashoffset"
                  begin="lineMdMoonAltLoop1.begin+1.2s;lineMdMoonAltLoop1.begin+3.2s;lineMdMoonAltLoop1.begin+5.2s"
                  dur="0.4s"
                  values="0;4"></animate><set
                  attributeName="d"
                  begin="lineMdMoonAltLoop1.begin+1.8s"
                  to="M17 11h1.5M17 11h-1.5M17 11v1.5M17 11v-1.5"></set><set
                  attributeName="d"
                  begin="lineMdMoonAltLoop1.begin+3.8s"
                  to="M18 12h1.5M18 12h-1.5M18 12v1.5M18 12v-1.5"></set><set
                  attributeName="d"
                  begin="lineMdMoonAltLoop1.begin+5.8s"
                  to="M19 11h1.5M19 11h-1.5M19 11v1.5M19 11v-1.5"></set></path
              ><path d="M19 4h1.5M19 4h-1.5M19 4v1.5M19 4v-1.5"
                ><animate
                  id="lineMdMoonAltLoop2"
                  fill="freeze"
                  attributeName="stroke-dashoffset"
                  begin="2.9s;lineMdMoonAltLoop2.begin+6s"
                  dur="0.4s"
                  values="4;0"></animate><animate
                  fill="freeze"
                  attributeName="stroke-dashoffset"
                  begin="lineMdMoonAltLoop2.begin+2s"
                  dur="0.4s"
                  values="4;0"></animate><animate
                  fill="freeze"
                  attributeName="stroke-dashoffset"
                  begin="lineMdMoonAltLoop2.begin+1.2s;lineMdMoonAltLoop2.begin+3.2s"
                  dur="0.4s"
                  values="0;4"></animate><set
                  attributeName="d"
                  begin="lineMdMoonAltLoop2.begin+1.8s"
                  to="M20 5h1.5M20 5h-1.5M20 5v1.5M20 5v-1.5"></set><set
                  attributeName="d"
                  begin="lineMdMoonAltLoop2.begin+5.8s"
                  to="M19 4h1.5M19 4h-1.5M19 4v1.5M19 4v-1.5"></set></path
              ></g
            ><path
              fill="none"
              stroke="var(--foreground)"
              stroke-dasharray="56"
              stroke-dashoffset="56"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M7 6 C7 12.08 11.92 17 18 17 C18.53 17 19.05 16.96 19.56 16.89 C17.95 19.36 15.17 21 12 21 C7.03 21 3 16.97 3 12 C3 8.83 4.64 6.05 7.11 4.44 C7.04 4.95 7 5.47 7 6 Z"
              ><animate fill="freeze" attributeName="stroke-dashoffset" dur="0.6s" values="56;0"></animate></path
            ></svg
          >
          <span class="visually-hidden">Activate light mode</span></button
        >
      </div>
    </header>
    <main>
      <section class="intro">
        <div>
          <h1 class="title">
            <span class="name">Kate Blake</span><br />
            Front End <Star class="icon" aria-hidden="true" /><br />
            Web <span class="underline">Developer</span>
          </h1>
          <p class="greetings handwriting">Nice to meet you :)</p>
          <a href="#work" class="get-started handwriting">
            Let's get started!
            <DownArrow aria-hidden="true" />
          </a>
        </div>
      </section>
      <section id="work">
        <h2><span class="underline">Featured</span> <Diamond aria-hidden="true" class="icon" /> Work</h2>
        <ul>
          <li>
            <article>
              <div class="border-glow" aria-hidden="true"></div>
              <Image src={aurecon} alt="Aurecon website preview" />
              <h3>Aurecon</h3>
              <ul class="technologies" aria-label="Technologies I used in Aurecon project:">
                <li>React</li>
                <li>Typescript</li>
                <li>Framer Motion</li>
                <li>Storybook</li>
              </ul>
              <p>
                A global engineering firm from the South Pacific. Big requirements for a big project. I focused on
                building their redesigned geo-location switcher, homepage animations and navigation in React with Framer
                Motion. Quite a deep dive into Typescript and managing complex components.
              </p>
              <a href="https://www.aurecongroup.com/"> View Aurecon Site </a>
            </article>
          </li>
          <li>
            <article>
              <div class="border-glow" aria-hidden="true"></div>
              <Image src={ngi} alt="Nedgroup Investments website preview" />
              <h3>Nedgroup Investments</h3>
              <ul class="technologies" aria-label="Technologies I used in Nedgroup Investments project:">
                <li>HTML</li>
                <li>SCSS</li>
                <li>JavaScript</li>
              </ul>
              <p>
                My very first production project :) I worked on dozens of components and layouts in vanilla HTML/CSS/JS
                (no frameworks), from staff portals to landing pages, all within a giant design system.
              </p>
              <a href="https://www.nedgroupinvestments.com/content/NGISingleSiteContent/Other.html"
                >View Nedgroup Investments Site</a
              >
            </article>
          </li>
          <li>
            <article>
              <div class="border-glow" aria-hidden="true"></div>
              <Image src={nml} alt="NML's 2023 yearend website preview" />
              <h3>NML 2023 Yearend</h3>
              <ul class="technologies" aria-label="Technologies I used in NML 2023 Yearend project:">
                <li>Next.js</li>
                <li>Typescript</li>
                <li>Tailwind CSS</li>
                <li>Framer Motion</li>
              </ul>
              <p>
                A fun internal year-end report site built with Next.js and Framer Motion. My first time using motion
                animations. Lots of playful UI, subtle transitions and even easter eggs!
              </p>
              <a href="https://yearend.nml.co.za/">View NML 2023 Yearend Site</a>
            </article>
          </li>
          <li>
            <article>
              <div class="border-glow" aria-hidden="true"></div>
              <Image src={storage} alt="Stor-Age website preview" />
              <h3>Stor-Age</h3>
              <ul class="technologies" aria-label="Technologies I used in Stor-Age project:">
                <li>Next.js</li>
                <li>Typescript</li>
                <li>Framer Motion</li>
                <li>Strapi</li>
              </ul>
              <p>
                Helped modernise the site for South Africa's leading self-storage brand. I rebuilt their store directory
                and landing pages in Next.js and hooked up Strapi CMS to replace parts of their old system.
              </p>
              <a href="https://www.stor-age.co.za/">View Stor-Age Site</a>
            </article>
          </li>
        </ul>
      </section>
      <section id="about">
        <h2>
          About <Heart2 class="icon" aria-hidden="true" />
          <span class="underline">Me</span>
        </h2>
        <p>
          I've been obsessed with tech ever since I got my first laptop at 10 and have never looked back. Today I'm an
          intermediate dev at NML, building complex frontends for big companies and ensuring they're accessible while
          I'm at it. I love getting stuck into CSS, upcoming web features and other cool things on the web. Outside of
          work, I'm studying towards a BSc in Computer Science (even if it means less sleep).
        </p>
        <div class="other-stuff">
          <div>
            <h3 id="other-stuff-i-like"><span class="underline">Other stuff I like:</span></h3>
            <ul aria-labelledby="other-stuff-i-like">
              <li>My cat Lilly</li>
              <li>3D Modelling</li>
              <li>Simulator games</li>
              <li>
                Movies that pass the <a href="https://bechdeltest.com/">Bechdel Test<CircleScribble /></a>
              </li>
              <li>Remembering all capital cities</li>
              <li>Pineapple on pizza</li>
            </ul>
            <p class="handwriting">
              Interact to see another pic of Lilly!<LillyArrow class="icon" aria-hidden="true" />
            </p>
          </div>
          <div>
            <button
              class="lilly-pics"
              type="button"
              aria-label="Toggle between different pictures of Lilly"
              aria-pressed="false"
            >
              <figure>
                <Image src={lilly1} alt="My cat Lilly lying outside looking content" />
                <figcaption>Lilly being a model.</figcaption>
              </figure>
              <figure>
                <Image src={lilly2} alt="Lilly crouched inside of an empty bag while poking her head out" />
                <figcaption>Lilly being a cave (bag) explorer.</figcaption>
              </figure>
            </button>
          </div>
        </div>
      </section>
      <section id="contact">
        <h2>
          <span class="underline">Contact</span>
          <Smile2 class="icon" aria-hidden="true" />
        </h2>
        <ul>
          <li>
            <a href="https://linkedin.com/in/kateblake3" aria-label="LinkedIn profile"
              ><LinkedIn aria-label="LinkedIn logo" /></a
            >
          </li>
          <li>
            <a href="https://github.com/yayokb" aria-label="GitHub profile"><Github aria-label="GitHub logo" /></a>
          </li>
          <li><a href="mailto:kateellablake@gmail.com">kateellablake@gmail.com</a></li>
        </ul>
      </section>
    </main>
    <footer>
      <p>
        2025. Developed by me, draft designed by <a href="https://portfolio-amber-jones-projects.vercel.app/"
          >Amber Jones</a
        >!
      </p>
    </footer>
    <script src="../scripts/theme-switch.js"></script>
    <script src="../scripts/lilly-pics-toggle.js"></script>
  </body>
</html>
